# ProxSync Backup Agent — configuration
# Install to /etc/proxsync-agent/agent.env with mode 0640, root:root.
# Every variable is prefixed PROXSYNC_AGENT_.

# ---- Service ---------------------------------------------------------------
# Set to the host's management IP — do NOT use 0.0.0.0.
# The installer (install-agent.sh --agent-ip) writes the actual value.
PROXSYNC_AGENT_BIND_HOST=<YOUR_MANAGEMENT_IP>
PROXSYNC_AGENT_BIND_PORT=8765
PROXSYNC_AGENT_LOG_LEVEL=INFO
PROXSYNC_AGENT_LOG_JSON=true

# ---- Transport security ----------------------------------------------------
# Mutual TLS. Without TLS_CLIENT_CA the agent still starts, but logs a warning: it is then
# protected only by the HMAC signature and the address allow-list.
PROXSYNC_AGENT_TLS_CERTFILE=/etc/proxsync-agent/tls/server.crt
PROXSYNC_AGENT_TLS_KEYFILE=/etc/proxsync-agent/tls/server.key
PROXSYNC_AGENT_TLS_CLIENT_CA=/etc/proxsync-agent/tls/ca.crt

# CIDRs allowed to reach the agent. Set this to the dashboard LXC address.
PROXSYNC_AGENT_ALLOWED_CLIENT_NETWORKS=10.0.0.20/32

# ---- Request signing -------------------------------------------------------
# Generate with: openssl rand -hex 32
# The dashboard must be configured with the identical value.
PROXSYNC_AGENT_API_KEY_ID=proxsync-dashboard
PROXSYNC_AGENT_HMAC_SECRET=CHANGE_ME_openssl_rand_hex_32
PROXSYNC_AGENT_SIGNATURE_WINDOW_SECONDS=60

# ---- Filesystem ------------------------------------------------------------
PROXSYNC_AGENT_DUMP_ROOT=/mnt/backup-hdd/dump
PROXSYNC_AGENT_TEMP_DIR=/mnt/backup-hdd/tmp
PROXSYNC_AGENT_STATE_DIR=/var/lib/proxsync-agent
PROXSYNC_AGENT_LOG_DIR=/var/log/proxsync-agent

# ---- Policy ----------------------------------------------------------------
# Empty allows any guest that exists on this host. Set it to pin an explicit allow-list.
PROXSYNC_AGENT_ALLOWED_VMIDS=
PROXSYNC_AGENT_ALLOWED_BACKUP_STORAGES=backup-hdd
# Empty allows any storage reported by pvesm as a restore target.
PROXSYNC_AGENT_ALLOWED_RESTORE_STORAGES=
PROXSYNC_AGENT_VERIFY_STORAGE_WITH_PVESM=true

PROXSYNC_AGENT_MAX_CONCURRENT_BACKUPS=1
PROXSYNC_AGENT_MAX_CONCURRENT_RESTORES=1

PROXSYNC_AGENT_BACKUP_TIMEOUT_SECONDS=43200
PROXSYNC_AGENT_RESTORE_TIMEOUT_SECONDS=43200
PROXSYNC_AGENT_CANCEL_GRACE_SECONDS=30

# Hashing a large artifact takes minutes; it runs at the end of the backup task, never
# inside a request. Disable only if the storage is already content-addressed.
PROXSYNC_AGENT_CHECKSUM_AFTER_BACKUP=true

PROXSYNC_AGENT_TASK_RETENTION_HOURS=336

# ---- Google Drive sync (M4) --------------------------------------------------
PROXSYNC_AGENT_SYNC_ENABLED=true
PROXSYNC_AGENT_RCLONE_BIN=/usr/bin/rclone
PROXSYNC_AGENT_RCLONE_CONFIG=/var/lib/proxsync-agent/rclone.conf

# Remotes this agent may address. STRONGLY recommended: an empty list permits any remote
# in rclone.conf, including a *local* one, which would turn an upload into an arbitrary
# file read. Name only the remotes you intend to use.
PROXSYNC_AGENT_ALLOWED_REMOTES=gdrive

PROXSYNC_AGENT_MAX_CONCURRENT_SYNCS=1
PROXSYNC_AGENT_SYNC_TIMEOUT_SECONDS=43200
PROXSYNC_AGENT_RCLONE_TRANSFERS=4
PROXSYNC_AGENT_RCLONE_CHECKERS=8
PROXSYNC_AGENT_RCLONE_LOW_LEVEL_RETRIES=3
PROXSYNC_AGENT_RCLONE_STATS_INTERVAL_SECONDS=5
