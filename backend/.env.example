# ProxSync dashboard API — configuration
# Install to /etc/proxsync/api.env with mode 0640.
# Every variable is prefixed PROXSYNC_.

# ---- Service ---------------------------------------------------------------
PROXSYNC_ENVIRONMENT=production
PROXSYNC_BIND_HOST=127.0.0.1
PROXSYNC_BIND_PORT=8000
PROXSYNC_LOG_LEVEL=INFO
PROXSYNC_LOG_JSON=true

# ---- Database --------------------------------------------------------------
# Async driver required. PostgreSQL: postgresql+asyncpg://proxsync:pass@host/proxsync
PROXSYNC_DATABASE_URL=sqlite+aiosqlite:////var/lib/proxsync/proxsync.db

# ---- Root secret -----------------------------------------------------------
# Generate with: openssl rand -hex 32
# The JWT signing key and the settings-encryption key are both derived from this via HKDF.
# Changing it invalidates every session AND makes stored secrets (e.g. the Telegram bot
# token) unreadable — they must be re-entered in Settings.
PROXSYNC_SECRET_KEY=CHANGE_ME_openssl_rand_hex_32

# ---- Authentication --------------------------------------------------------
PROXSYNC_ACCESS_TOKEN_TTL_SECONDS=900
PROXSYNC_REFRESH_TOKEN_TTL_SECONDS=604800
PROXSYNC_COOKIE_SECURE=true
# Set false only when serving over plain HTTP during development.

PROXSYNC_LOGIN_MAX_ATTEMPTS=5
PROXSYNC_LOGIN_ATTEMPT_WINDOW_SECONDS=900
PROXSYNC_LOGIN_LOCKOUT_BASE_SECONDS=60
PROXSYNC_LOGIN_LOCKOUT_MAX_SECONDS=3600

# Argon2id. Raising these later is safe: passwords are transparently re-hashed on next login.
PROXSYNC_ARGON2_TIME_COST=3
PROXSYNC_ARGON2_MEMORY_COST=65536
PROXSYNC_ARGON2_PARALLELISM=4

# First-run only. The account is created with must_change_password set; remove this line
# after the first successful sign-in.
PROXSYNC_BOOTSTRAP_ADMIN_USERNAME=admin
PROXSYNC_BOOTSTRAP_ADMIN_PASSWORD=

# ---- Backup Agent ----------------------------------------------------------
# Printed by deploy/host/install-agent.sh. These are bootstrap credentials and stay in the
# environment: they are not stored in the database.
PROXSYNC_AGENT_BASE_URL=https://10.0.0.10:8765
PROXSYNC_AGENT_API_KEY_ID=proxsync-dashboard
PROXSYNC_AGENT_HMAC_SECRET=CHANGE_ME_same_value_as_the_agent
PROXSYNC_AGENT_CA_CERT=/etc/proxsync/agent-ca.crt
PROXSYNC_AGENT_CLIENT_CERT=/etc/proxsync/agent-client.crt
PROXSYNC_AGENT_CLIENT_KEY=/etc/proxsync/agent-client.key
PROXSYNC_AGENT_TIMEOUT_SECONDS=30
PROXSYNC_AGENT_CIRCUIT_FAILURE_THRESHOLD=3
PROXSYNC_AGENT_CIRCUIT_RESET_SECONDS=30

# ---- Proxmox API (read-only inventory) -------------------------------------
# Create with:
#   pveum user add proxsync@pve
#   pveum acl modify / --users proxsync@pve --roles PVEAuditor
#   pveum user token add proxsync@pve dashboard --privsep 0
# PVEAuditor is read-only: this token cannot start, stop or delete anything.
PROXSYNC_PROXMOX_BASE_URL=https://10.0.0.10:8006
PROXSYNC_PROXMOX_TOKEN_ID=proxsync@pve!dashboard
PROXSYNC_PROXMOX_TOKEN_SECRET=
PROXSYNC_PROXMOX_NODE=pve
PROXSYNC_PROXMOX_VERIFY_TLS=true
PROXSYNC_PROXMOX_CA_CERT=/etc/proxsync/pve-ca.crt
PROXSYNC_PROXMOX_TIMEOUT_SECONDS=15.0

# ---- Background workers -----------------------------------------------------
# Master switch for the run executor, the scheduler and the inventory refresh.
# The run executor also reconciles backups the previous process left in flight, so
# disabling it leaves those rows stuck in `running` until it is turned back on.
PROXSYNC_BACKGROUND_WORKERS=true
PROXSYNC_SCHEDULER_ENABLED=true

# How late a schedule missed while the service was down may still run. Beyond this the
# firing is skipped and logged: a weekly backup starting unattended three days late is
# more surprising than one that did not start at all.
PROXSYNC_SCHEDULER_MISFIRE_GRACE_SECONDS=3600

# How long a running backup may go unpolled before its outcome is recorded as
# `interrupted`. Not `failed` — the vzdump may well have succeeded, and retention would
# then act on a lie.
PROXSYNC_AGENT_UNREACHABLE_GRACE_SECONDS=1800

# Backstop for the run queue's doorbell; the normal path does not wait for it.
PROXSYNC_RUN_IDLE_POLL_SECONDS=5.0
PROXSYNC_EVENTS_QUEUE_SIZE=200

# How often the upload queue re-checks for work. Also drives the retry schedule: a transfer
# waiting on backoff becomes ready without anything ringing a doorbell for it.
PROXSYNC_SYNC_IDLE_POLL_SECONDS=10.0

# Exponential backoff with full jitter between upload attempts. Jittered because the common
# failure is a Drive quota shared by every pending transfer, and retrying them in lockstep
# would reproduce the burst that caused it.
PROXSYNC_SYNC_RETRY_BASE_SECONDS=30
PROXSYNC_SYNC_RETRY_MAX_SECONDS=3600

# Backstop for the restore executor's doorbell, and the cadence of its expiry sweep.
PROXSYNC_RESTORE_IDLE_POLL_SECONDS=5.0

# How long a restore may sit in `pending_confirmation` before it expires. Short on purpose:
# the token is what turns "I clicked restore" into "I meant this guest, now", and a window
# measured in hours would let a stale tab confirm against an inventory that has since changed.
PROXSYNC_RESTORE_CONFIRMATION_TTL_SECONDS=300

# Capture local usage and the best-effort Drive quota every 15 minutes. Failed local reads
# are skipped rather than stored as zeros, because false samples would corrupt the forecast.
PROXSYNC_STORAGE_SAMPLE_INTERVAL_SECONDS=900

# ---- Notifications ----------------------------------------------------------
# The bot token and chat id are *not* here: they are operator settings, stored encrypted in
# the database and edited in Settings → Telegram. Only delivery mechanics live in the
# environment.
PROXSYNC_TELEGRAM_API_BASE_URL=https://api.telegram.org
PROXSYNC_TELEGRAM_TIMEOUT_SECONDS=15.0

# Backstop for the outbox doorbell; also what makes a scheduled retry become ready.
PROXSYNC_NOTIFICATION_IDLE_POLL_SECONDS=15.0

# Exponential backoff with full jitter between delivery attempts. A refusal Telegram will
# repeat forever (a bad token, an unknown chat) is terminal on the first attempt instead, so
# these apply only to outages and rate limits.
PROXSYNC_NOTIFICATION_MAX_ATTEMPTS=5
PROXSYNC_NOTIFICATION_RETRY_BASE_SECONDS=30
PROXSYNC_NOTIFICATION_RETRY_MAX_SECONDS=3600

# How long an identical report counts as a repeat rather than news. Applies only to events
# that genuinely recur (a storage threshold, a retention pass); one-per-occurrence events are
# keyed uniquely and never depend on a clock.
PROXSYNC_NOTIFICATION_SUPPRESS_WINDOW_SECONDS=300

# ---- Log persistence --------------------------------------------------------
# Writes structlog output to the `logs` table behind /logs. Capture is a bounded in-memory
# buffer drained by a worker: a log call never blocks, and a full buffer drops its oldest
# entry rather than slowing a backup. The drop count is reported in /health/detail.
PROXSYNC_LOG_PERSIST_ENABLED=true

# Floor for persistence only; console output still honours PROXSYNC_LOG_LEVEL.
PROXSYNC_LOG_PERSIST_LEVEL=INFO
PROXSYNC_LOG_BUFFER_SIZE=2000
PROXSYNC_LOG_FLUSH_INTERVAL_SECONDS=2.0
PROXSYNC_LOG_FLUSH_BATCH_SIZE=200

# Cadence of the retention pass over `logs` and `audit_events`. The *ages* are operator
# settings (general.log_retention_days, general.audit_retention_days), not environment.
PROXSYNC_LOG_PRUNE_INTERVAL_SECONDS=86400

# ---- Frontend --------------------------------------------------------------
# Leave empty when nginx serves the UI from the same origin (the default deployment).
PROXSYNC_CORS_ORIGINS=
PROXSYNC_DEFAULT_TIMEZONE=Asia/Jakarta
